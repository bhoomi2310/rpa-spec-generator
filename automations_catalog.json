[
  {
    "id": "employee_onboarding",
    "name": "Employee Onboarding",
    "description": "Onboard a new employee by provisioning accounts, departments, and sending orientation documents.",
    "keywords": ["onboard", "new hire", "employee onboarding", "welcome new employee", "joining"],
    "required_inputs": [
      {
        "field": "full_name",
        "label": "Full Name",
        "type": "text",
        "placeholder": "John Doe"
      },
      {
        "field": "email",
        "label": "Email Address",
        "type": "email",
        "placeholder": "john.doe@company.com"
      },
      {
        "field": "department",
        "label": "Department",
        "type": "dropdown",
        "options": ["HR", "IT", "Finance", "Operations"],
        "placeholder": "Select Department"
      },
      {
        "field": "joining_date",
        "label": "Joining Date",
        "type": "date",
        "placeholder": "YYYY-MM-DD"
      }
    ],
    "expected_outputs": [
      "Active Directory Account provisioned",
      "Welcome onboarding email sent to new hire",
      "Orientation schedule calendar invite generated"
    ]
  },
